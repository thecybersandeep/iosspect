<?xml version="1.0" encoding="UTF-8"?>
<!--
  Entitlements for the daemon. Runs as root from a LaunchDaemon, so it
  gets root capabilities by default. These additional flags let it:
    - posix_spawn arbitrary binaries (uiopen, openssl, netstat, tail)
    - read /var/mobile + /var/containers without per-container sandbox
    - resolve installed apps via MobileInstallation plist + LS workspace
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>platform-application</key>
    <true/>
    <key>com.apple.private.security.no-container</key>
    <true/>
    <key>com.apple.private.security.no-sandbox</key>
    <true/>
    <key>com.apple.private.persona-mgmt</key>
    <true/>
    <key>com.apple.private.MobileContainerManager.allowed</key>
    <true/>
    <key>com.apple.private.security.disk-device-access</key>
    <true/>
    <key>get-task-allow</key>
    <true/>
</dict>
</plist>
